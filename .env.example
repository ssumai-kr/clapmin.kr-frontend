# YouTube Video ID
# Get the video ID from YouTube URL: https://www.youtube.com/watch?v=VIDEO_ID
# Example: QwByM5-vwlM
VITE_YOUTUBE_VIDEO_ID=QwByM5-vwlM

# GitHub Personal Access Token (only read:user scope needed)
# Generate at https://github.com/settings/tokens
VITE_GITHUB_TOKEN=your_github_token_here
